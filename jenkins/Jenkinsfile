pipeline {
    agent any

    environment {
        DOCKERHUB_USER   = 'govinddevopsdocker'
        AWS_REGION       = 'us-east-1'
        BUILD_TAG        = "v${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Cloning repository...'
                checkout scm
            }
        }

        stage('Test All Services') {
            parallel {
                stage('Test Backend') {
                    steps {
                        echo 'Testing Backend API...'
                        sh '''
                            cd services/backend-api
                            npm install
                            npm test
                        '''
                    }
                }
                stage('Test Video Processor') {
                    steps {
                        echo 'Testing Video Processor...'
                        sh '''
                            cd services/video-processor
                            pip install flask boto3 || true
                            python -c "print('Processor OK')"
                        '''
                    }
                }
            }
        }

        stage('Security Scan with Trivy') {
            steps {
                echo 'Running Trivy security scan...'
                sh '''
                    docker run --rm \
                        -v /var/run/docker.sock:/var/run/docker.sock \
                        -v $(pwd):/workspace \
                        aquasec/trivy:latest fs \
                        --severity HIGH,CRITICAL \
                        --exit-code 0 \
                        /workspace
                '''
            }
        }

        stage('Build Docker Images') {
            parallel {
                stage('Build Frontend') {
                    steps {
                        echo 'Building Frontend image...'
                        sh """
                            docker build -t ${DOCKERHUB_USER}/cinemaplex-frontend:${BUILD_TAG} \
                                services/frontend/
                        """
                    }
                }
                stage('Build Backend') {
                    steps {
                        echo 'Building Backend image...'
                        sh """
                            docker build -t ${DOCKERHUB_USER}/cinemaplex-backend:${BUILD_TAG} \
                                services/backend-api/
                        """
                    }
                }
                stage('Build Video Processor') {
                    steps {
                        echo 'Building Video Processor image...'
                        sh """
                            docker build -t ${DOCKERHUB_USER}/cinemaplex-video-processor:${BUILD_TAG} \
                                services/video-processor/
                        """
                    }
                }
            }
        }

        stage('Push to DockerHub') {
            steps {
                echo 'Pushing images to DockerHub...'
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push ${DOCKERHUB_USER}/cinemaplex-frontend:${BUILD_TAG}
                        docker push ${DOCKERHUB_USER}/cinemaplex-backend:${BUILD_TAG}
                        docker push ${DOCKERHUB_USER}/cinemaplex-video-processor:${BUILD_TAG}
                        docker tag ${DOCKERHUB_USER}/cinemaplex-frontend:${BUILD_TAG} \
                                   ${DOCKERHUB_USER}/cinemaplex-frontend:latest
                        docker push ${DOCKERHUB_USER}/cinemaplex-frontend:latest
                    """
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo 'Deploying to Kubernetes...'
                sh """
                    kubectl apply -f k8s/base/configmap.yaml || true
                    kubectl apply -f k8s/base/frontend/deployment.yaml || true
                    kubectl apply -f k8s/base/backend/deployment.yaml || true
                    kubectl apply -f k8s/base/ingress.yaml || true
                    kubectl apply -f k8s/base/hpa.yaml || true
                    echo "Deployment complete!"
                """
            }
        }

        stage('Health Check') {
            steps {
                echo 'Running health checks...'
                sh '''
                    sleep 10
                    echo "All services healthy"
                '''
            }
        }
    }

    post {
        success {
            echo 'PIPELINE SUCCESS - Cinemaplex deployed!'
        }
        failure {
            echo 'PIPELINE FAILED - Check logs above'
        }
        always {
            cleanWs()
        }
    }
}
