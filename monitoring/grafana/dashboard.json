{
  "dashboard": {
    "title": "Cinemaplex DevOps Dashboard",
    "uid": "cinemaplex-main",
    "panels": [
      {
        "title": "Active Video Streams",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [{
          "expr": "cinemaplex_active_streams",
          "legendFormat": "Active Streams"
        }]
      },
      {
        "title": "Total Requests",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [{
          "expr": "cinemaplex_requests_total",
          "legendFormat": "Total Requests"
        }]
      },
      {
        "title": "Bandwidth Usage",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [{
          "expr": "rate(cinemaplex_bandwidth_bytes[5m])",
          "legendFormat": "Bandwidth/s"
        }]
      },
      {
        "title": "CPU Usage per Pod",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [{
          "expr": "rate(container_cpu_usage_seconds_total[5m])",
          "legendFormat": "{{pod}}"
        }]
      }
    ]
  }
}
